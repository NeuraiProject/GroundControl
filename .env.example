# Neurai RPC. Either:
#   - the public anonymous endpoint provided by the Neurai project:
#       mainnet: https://rpc-main.neurai.org/rpc
#       testnet: https://rpc-testnet.neurai.org/rpc
#   - or a self-hosted node: http://username:password@127.0.0.1:9817
# Pick one chain per deployment. To watch both mainnet and testnet you need
# two GroundControl instances (separate DBs).
NEURAI_RPC=https://rpc-main.neurai.org/rpc

# MariaDB / MySQL connection URL.
# Example: mysql://groundcontrol:secret@127.0.0.1:3306/groundcontrol
JAWSDB_MARIA_URL=

# APNs (Apple Push Notifications) credentials.
# Generate the .p8 in Apple Developer Portal → Keys → Push Notifications.
APNS_P8=                  # hex-encoded contents of the .p8 file
APNS_P8_KID=              # "Key ID" of that .p8
APPLE_TEAM_ID=            # Team ID of the Apple developer account
# The iOS bundle ID of the wallet app. Currently the Xcode target is still
# named BlueWallet, so the IPA ships with this bundle ID. Update when the
# Xcode project gets renamed.
APNS_TOPIC=io.bluewallet.bluewallet

# FCM (Firebase Cloud Messaging) HTTP v1 credentials.
GOOGLE_KEY_FILE=          # hex-encoded service-account JSON key
GOOGLE_PROJECT_ID=        # Firebase project id

# Set to non-empty for verbose logging.
VERBOSE=
